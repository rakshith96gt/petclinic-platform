{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-destroy.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-dangerous-rm.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/warn-apply-without-plan.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-secret-commit.sh"
          }
        ]
      },
      {
        "matcher": "mcp__.*__ExecuteTerraformCommand|mcp__.*__ExecuteTerragruntCommand",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-mcp-destroy.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/suggest-validate.sh"
          }
        ]
      }
    ]
  }
}
